{
    "name": "developertugrul/garanti-pos",
    "description": "Garanti BBVA Virtual POS integration package for Laravel",
    "type": "library",
    "keywords": [
        "laravel",
        "garanti",
        "pos",
        "sanal pos",
        "payment"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Tugrul",
            "email": "contact@tugrulyildirim.com"
        }
    ],
    "require": {
        "php": "^8.0",
        "illuminate/support": "^9.0|^10.0|^11.0",
        "illuminate/http": "^9.0|^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Developertugrul\\GarantiPos\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Developertugrul\\GarantiPos\\GarantiPosServiceProvider"
            ],
            "aliases": {
                "GarantiPos": "Developertugrul\\GarantiPos\\Facades\\GarantiPos"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "version": "1.0.8"
}